{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/systems/western-astrology/calculator/output.schema.json",
  "title": "Western natal calculator output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "engine", "raw_input", "normalized_input", "computed_facts", "derived_findings", "narrative", "validation"],
  "properties": {
    "schema_version": { "const": "0.3.0" },
    "engine": { "type": "object" },
    "raw_input": { "type": "object" },
    "normalized_input": { "type": "object" },
    "computed_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["positions", "angles", "house_cusps", "aspects"],
      "properties": {
        "positions": { "type": "array", "minItems": 10, "maxItems": 10, "items": { "$ref": "#/$defs/position" } },
        "angles": {
          "type": "object",
          "required": ["ascendant", "midheaven"],
          "properties": {
            "ascendant": { "$ref": "#/$defs/angle" },
            "midheaven": { "$ref": "#/$defs/angle" }
          }
        },
        "house_cusps": { "type": "array", "minItems": 12, "maxItems": 12 },
        "aspects": { "type": "array" }
      }
    },
    "derived_findings": { "type": "array" },
    "narrative": { "type": ["object", "null"] },
    "validation": { "type": "object" }
  },
  "$defs": {
    "position": {
      "type": "object",
      "required": ["fact_id", "body", "longitude_degrees", "latitude_degrees", "distance_au", "speed_degrees_per_day", "retrograde", "sign", "sign_index", "degree_in_sign", "rule_ids", "source_ids", "house"],
      "properties": {
        "fact_id": { "type": "string" },
        "body": { "type": "string" },
        "longitude_degrees": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "latitude_degrees": { "type": "number" },
        "distance_au": { "type": "number", "exclusiveMinimum": 0 },
        "speed_degrees_per_day": { "type": "number" },
        "retrograde": { "type": "boolean" },
        "sign": { "type": "string" },
        "sign_index": { "type": "integer", "minimum": 0, "maximum": 11 },
        "degree_in_sign": { "type": "number", "minimum": 0, "exclusiveMaximum": 30 },
        "source_ids": { "type": "array", "minItems": 1 },
        "rule_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "house": { "type": "integer", "minimum": 1, "maximum": 12 },
        "traditional_condition": {
          "type": "object",
          "required": [
            "fact_id",
            "lineage",
            "statuses",
            "domicile_signs",
            "detriment_signs",
            "exaltation_sign",
            "fall_sign",
            "scoring_applied",
            "rule_ids",
            "source_ids"
          ]
        }
      }
    },
    "angle": {
      "type": "object",
      "required": ["fact_id", "longitude_degrees", "sign", "degree_in_sign", "rule_ids", "source_ids"],
      "properties": {
        "fact_id": { "type": "string" },
        "longitude_degrees": { "type": "number", "minimum": 0, "exclusiveMaximum": 360 },
        "sign": { "type": "string" },
        "degree_in_sign": { "type": "number", "minimum": 0, "exclusiveMaximum": 30 },
        "source_ids": { "type": "array", "minItems": 1 },
        "rule_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
