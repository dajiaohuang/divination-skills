{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/systems/vedic-astrology/calculator/output.schema.json",
  "title": "Vedic multi-lineage calculator output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "engine",
    "raw_input",
    "normalized_input",
    "computed_facts",
    "derived_findings",
    "narrative",
    "validation",
    "trace"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "engine": {"type": "object"},
    "raw_input": {"type": "object"},
    "normalized_input": {"type": "object"},
    "computed_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["astronomy", "sidereal_chart", "lineages"],
      "properties": {
        "astronomy": {"type": "object"},
        "sidereal_chart": {
          "type": "object",
          "required": ["lagna", "positions", "house_policy", "rule_ids", "source_ids"],
          "properties": {
            "lagna": {"type": "object"},
            "positions": {"type": "array", "minItems": 9, "maxItems": 9},
            "house_policy": {"const": "whole_sign_from_sidereal_lagna"},
            "rule_ids": {"type": "array", "minItems": 1},
            "source_ids": {"type": "array", "minItems": 1}
          }
        },
        "lineages": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 3,
          "propertyNames": {"enum": ["parashari", "jaimini", "kp"]}
        }
      }
    },
    "derived_findings": {"type": "array", "maxItems": 0},
    "narrative": {"type": "null"},
    "validation": {"type": "object"},
    "trace": {"type": "array", "minItems": 4}
  }
}
