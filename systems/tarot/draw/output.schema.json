{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/systems/tarot/draw/output.schema.json",
  "title": "Auditable Tarot draw output",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "engine", "normalized_input", "audit", "computed_facts", "derived_findings", "narrative", "validation"],
  "properties": {
    "schema_version": { "const": "0.3.0" },
    "engine": { "type": "object" },
    "normalized_input": { "type": "object" },
    "audit": {
      "type": "object",
      "required": ["algorithm", "seed_hex", "seed_commitment", "deck_sha256", "draw_id"],
      "properties": {
        "algorithm": { "const": "sha256-counter-rejection-v1" },
        "seed_hex": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "seed_commitment": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "deck_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "draw_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "computed_facts": {
      "type": "object",
      "required": ["spread", "cards"],
      "properties": {
        "spread": { "type": "string" },
        "cards": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "object",
            "required": ["fact_id", "position", "card_id", "card_index", "name", "arcana", "deck_index", "rank", "suit", "element", "orientation", "identity_lineage", "source_ids"],
            "properties": {
              "fact_id": { "type": "string" },
              "position": { "type": "string" },
              "card_id": { "type": "string" },
              "card_index": { "type": "integer", "minimum": 0, "maximum": 77 },
              "name": { "type": "string" },
              "arcana": { "type": "string", "enum": ["major", "minor"] },
              "deck_index": { "type": "integer", "minimum": 0, "maximum": 77 },
              "rank": { "type": ["string", "null"] },
              "suit": { "type": ["string", "null"], "enum": ["wands", "cups", "swords", "pentacles", null] },
              "element": { "type": ["string", "null"], "enum": ["fire", "water", "air", "earth", null] },
              "orientation": { "type": "string", "enum": ["upright", "reversed"] },
              "identity_lineage": { "const": "rws-identity-v0.3" },
              "source_ids": {
                "type": "array",
                "minItems": 2,
                "contains": { "const": "SRC-TAROT-WAITE-WIKISOURCE-001" },
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "derived_findings": { "type": "array" },
    "narrative": { "type": ["object", "null"] },
    "validation": { "type": "object", "required": ["status", "warnings"] }
  }
}
