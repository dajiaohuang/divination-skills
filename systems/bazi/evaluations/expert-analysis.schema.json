{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/systems/bazi/evaluations/expert-analysis.schema.json",
  "title": "Bazi expert-analysis review candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["analysis_id", "case_id", "data_classification", "computed_facts_sha256", "reasoning_chain", "review"],
  "properties": {
    "analysis_id": { "type": "string", "pattern": "^ANALYSIS-BAZI-[0-9]{3}$" },
    "case_id": { "type": "string", "pattern": "^CASE-BAZI-[A-Z0-9-]+$" },
    "data_classification": { "const": "synthetic" },
    "computed_facts_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "strength_lineage": { "type": ["string", "null"] },
    "reasoning_chain": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "section", "statement", "fact_ids", "rule_ids"],
        "properties": {
          "claim_id": { "type": "string", "pattern": "^CLAIM-[0-9]{3}$" },
          "section": { "type": "string", "enum": ["calculation_basis", "verified_facts", "symbolic_relationships", "seasonal_support_path", "method_specific_timing"] },
          "statement": { "type": "string", "minLength": 1 },
          "fact_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
          "rule_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^BAZI-[A-Z0-9-]+$" } },
          "features": { "type": "object" }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewer_id", "reviewed_at", "decision", "notes"],
      "properties": {
        "status": { "type": "string", "enum": ["pending_expert", "reviewed"] },
        "reviewer_id": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"], "format": "date" },
        "decision": { "type": ["string", "null"], "enum": ["accepted", "changes_requested", "rejected", null] },
        "notes": { "type": "string" }
      }
    }
  }
}
