{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/systems/bazi/calculator/output.schema.json",
  "title": "Bazi calculator output v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "engine",
    "raw_input",
    "normalized_input",
    "computed_facts",
    "derived_findings",
    "narrative",
    "validation"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "dependencies", "source_ids"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "dependencies": { "type": "object", "additionalProperties": { "type": "string" } },
        "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "raw_input": { "type": "object" },
    "normalized_input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_datetime",
        "utc_datetime",
        "beijing_datetime",
        "timezone",
        "utc_offset_seconds",
        "fold",
        "day_boundary",
        "longitude",
        "latitude",
        "true_solar_time_applied",
        "luck_cycle_direction"
      ],
      "properties": {
        "local_datetime": { "type": "string" },
        "utc_datetime": { "type": "string" },
        "beijing_datetime": { "type": "string" },
        "timezone": { "type": "string" },
        "utc_offset_seconds": { "type": "integer" },
        "fold": { "type": "integer", "enum": [0, 1] },
        "day_boundary": { "type": "string", "enum": ["midnight", "zi_initial"] },
        "longitude": { "type": ["number", "null"] },
        "latitude": { "type": ["number", "null"] },
        "true_solar_time_applied": { "const": false },
        "luck_cycle_direction": { "type": ["string", "null"] }
      }
    },
    "computed_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solar_year",
        "previous_month_boundary",
        "next_month_boundary",
        "pillars",
        "day_master",
        "ten_gods",
        "branch_relations",
        "luck_cycles"
      ],
      "properties": {
        "solar_year": { "type": "integer" },
        "previous_month_boundary": { "$ref": "#/$defs/solarTerm" },
        "next_month_boundary": { "$ref": "#/$defs/solarTerm" },
        "pillars": {
          "type": "object",
          "additionalProperties": false,
          "required": ["year", "month", "day", "hour"],
          "properties": {
            "year": { "$ref": "#/$defs/pillar" },
            "month": { "$ref": "#/$defs/pillar" },
            "day": { "$ref": "#/$defs/pillar" },
            "hour": { "$ref": "#/$defs/pillar" }
          }
        },
        "day_master": { "type": "object" },
        "ten_gods": { "type": "object" },
        "branch_relations": { "type": "array", "items": { "type": "object" } },
        "luck_cycles": { "type": ["object", "null"] }
      }
    },
    "derived_findings": { "type": "array" },
    "narrative": { "type": ["object", "string", "null"] },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "warnings"],
      "properties": {
        "status": { "const": "valid" },
        "warnings": { "type": "array", "items": { "type": "object" } }
      }
    }
  },
  "$defs": {
    "solarTerm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "month_sequence", "solar_longitude_degrees", "beijing_datetime", "utc_datetime"],
      "properties": {
        "name": { "type": "string" },
        "month_sequence": { "type": "integer", "minimum": 0, "maximum": 11 },
        "solar_longitude_degrees": { "type": "integer" },
        "beijing_datetime": { "type": "string" },
        "utc_datetime": { "type": "string" }
      }
    },
    "pillar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fact_id", "index", "ganzhi", "stem", "branch", "source_ids"],
      "properties": {
        "fact_id": { "type": "string" },
        "index": { "type": "integer", "minimum": 0, "maximum": 59 },
        "ganzhi": { "type": "string", "minLength": 2, "maxLength": 2 },
        "stem": { "type": "object" },
        "branch": { "type": "object" },
        "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
