{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/systems/bazi/calculator/input.schema.json",
  "title": "Bazi calculator input v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["local_datetime", "timezone"],
  "properties": {
    "local_datetime": { "type": "string", "minLength": 16 },
    "timezone": { "type": "string", "minLength": 1 },
    "fold": { "type": "integer", "enum": [0, 1] },
    "day_boundary": { "type": "string", "enum": ["midnight", "zi_initial"], "default": "midnight" },
    "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
    "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
    "luck_cycle_direction": { "type": "string", "enum": ["forward", "reverse"] },
    "time_basis": {
      "type": "string",
      "enum": ["civil", "apparent_solar"],
      "default": "civil"
    },
    "true_solar_time": {
      "type": "boolean",
      "description": "Backward-compatible alias: true selects apparent_solar.",
      "default": false
    }
  }
}
