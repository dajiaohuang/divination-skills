{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/schemas/multi-natal-input.schema.json",
  "title": "Multi-natal synthesis input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "birth_date",
    "birth_time",
    "birthplace",
    "calculation_gender"
  ],
  "properties": {
    "birth_date": {
      "type": "string",
      "format": "date"
    },
    "birth_time": {
      "type": "string",
      "pattern": "^(?:[01][0-9]|2[0-3]):[0-5][0-9](?::[0-5][0-9](?:[.][0-9]{1,6})?)?$"
    },
    "birthplace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "timezone",
        "longitude",
        "latitude",
        "resolution_source"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "latitude": {
          "type": "number",
          "minimum": -89,
          "maximum": 89
        },
        "resolution_source": {
          "type": "string",
          "enum": [
            "user_confirmed",
            "gazetteer",
            "geocoder"
          ]
        },
        "source_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://"
        }
      }
    },
    "calculation_gender": {
      "type": "string",
      "enum": [
        "male",
        "female"
      ]
    },
    "fold": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "east_asian_time_basis": {
          "type": "string",
          "enum": [
            "civil",
            "apparent_solar"
          ]
        },
        "bazi_day_boundary": {
          "type": "string",
          "enum": [
            "midnight",
            "zi_initial"
          ]
        },
        "bazi_luck_cycle_direction": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "forward",
            "reverse",
            null
          ]
        },
        "western_house_system": {
          "type": "string",
          "enum": [
            "whole_sign",
            "equal"
          ]
        },
        "ziwei_year_boundary": {
          "type": "string",
          "enum": [
            "lunar_new_year",
            "spring_commences"
          ]
        },
        "ziwei_late_zi_policy": {
          "type": "string",
          "enum": [
            "current_day",
            "next_day"
          ]
        },
        "ziwei_leap_month_policy": {
          "type": "string",
          "enum": [
            "preserve",
            "previous_month",
            "next_month",
            "split_after_15"
          ]
        },
        "vedic_lineages": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "parashari",
              "jaimini",
              "kp"
            ]
          }
        },
        "jaimini_karaka_policy": {
          "type": "string",
          "enum": [
            "seven",
            "eight"
          ]
        }
      }
    },
    "numerology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "transliteration": {
          "type": "string",
          "minLength": 1
        },
        "mappings": {
          "type": "array",
          "minItems": 1,
          "maxItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "pythagorean",
              "chaldean"
            ]
          }
        }
      }
    }
  }
}
