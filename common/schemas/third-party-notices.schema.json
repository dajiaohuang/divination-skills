{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/schemas/third-party-notices.schema.json",
  "title": "Skill third-party notices",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundled", "required_but_not_bundled"],
  "properties": {
    "bundled": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "license", "license_files"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "license": { "type": "string", "minLength": 1 },
          "license_files": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "required_but_not_bundled": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
