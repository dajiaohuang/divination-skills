{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/schemas/timeline.schema.json",
  "title": "Cross-system calculated timeline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timeline_id",
    "system",
    "lineage",
    "chart_id",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "timeline_id": { "type": "string", "pattern": "^TIMELINE-[A-F0-9]{16}$" },
    "system": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "lineage": { "type": "string", "minLength": 1 },
    "chart_id": { "type": "string", "pattern": "^CHART-[A-Z0-9-]+$" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "scope",
          "start",
          "end",
          "start_inclusive",
          "end_inclusive",
          "fact_ids",
          "rule_ids",
          "confidence"
        ],
        "properties": {
          "entry_id": { "type": "string", "pattern": "^TIME-[A-Z0-9-]+$" },
          "scope": {
            "type": "string",
            "enum": [
              "major_period",
              "subperiod",
              "year",
              "month",
              "day",
              "hour",
              "transit",
              "return",
              "progression",
              "custom"
            ]
          },
          "start": { "type": "string", "format": "date-time" },
          "end": { "type": "string", "format": "date-time" },
          "start_inclusive": { "type": "boolean" },
          "end_inclusive": { "type": "boolean" },
          "fact_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "rule_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9]+(?:-[A-Z0-9]+){2,}$"
            }
          },
          "confidence": { "type": "string", "enum": ["deterministic", "high", "medium", "low"] }
        }
      }
    }
  }
}
