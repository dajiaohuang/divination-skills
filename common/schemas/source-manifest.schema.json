{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/schemas/source-manifest.schema.json",
  "title": "Divination source manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_id",
    "title",
    "creators",
    "source_type",
    "language",
    "locators",
    "retrieved_at",
    "license",
    "rights",
    "rights_review",
    "usage_status",
    "systems",
    "lineages",
    "quality"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)+$"
    },
    "title": { "type": "string", "minLength": 1 },
    "creators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": {
            "type": "string",
            "enum": ["author", "editor", "translator", "maintainer", "publisher", "organization", "unknown"]
          }
        }
      }
    },
    "source_type": {
      "type": "string",
      "enum": ["book", "article", "paper", "standard", "dataset", "software", "website", "interview", "case_collection", "other"]
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(?:-[A-Z][a-z]{3})?(?:-[A-Z]{2}|-[0-9]{3})?$"
    },
    "publication_date": { "type": "string", "minLength": 4 },
    "edition_or_version": { "type": "string", "minLength": 1 },
    "locators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "value", "stable"],
        "properties": {
          "kind": { "type": "string", "enum": ["url", "doi", "isbn", "repository", "archive", "library", "local"] },
          "value": { "type": "string", "minLength": 1 },
          "stable": { "type": "boolean" }
        }
      }
    },
    "retrieved_at": { "type": "string", "format": "date" },
    "local_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retained"],
      "properties": {
        "retained": { "type": "boolean" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "text_available", "additional_terms"],
      "properties": {
        "identifier": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "text_available": { "type": "boolean" },
        "additional_terms": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commercial_use", "derivative_use", "translation", "images", "dataset"],
      "properties": {
        "commercial_use": { "$ref": "#/$defs/rightStatus" },
        "derivative_use": { "$ref": "#/$defs/rightStatus" },
        "translation": { "$ref": "#/$defs/rightStatus" },
        "images": { "$ref": "#/$defs/rightStatus" },
        "dataset": { "$ref": "#/$defs/rightStatus" },
        "notes": { "type": "string" }
      }
    },
    "rights_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_at", "evidence"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "accepted", "reference_only", "rejected"] },
        "reviewer": { "type": "string", "minLength": 1 },
        "reviewed_at": { "type": "string", "format": "date" },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "usage_status": {
      "type": "string",
      "enum": ["proposed", "reference_only", "rights_checked", "extracted", "reviewed", "tested", "production", "rejected"]
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "lineages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "independence", "reliability", "notes"],
      "properties": {
        "authority": { "type": "string", "enum": ["primary", "official", "scholarly", "practitioner", "community", "unknown"] },
        "independence": { "type": "string", "enum": ["independent", "derived", "unknown"] },
        "reliability": { "type": "string", "enum": ["high", "medium", "low", "unrated"] },
        "notes": { "type": "string" }
      }
    },
    "notes": { "type": "string" }
  },
  "$defs": {
    "rightStatus": {
      "type": "string",
      "enum": ["allowed", "prohibited", "permission_required", "unknown", "not_applicable"]
    }
  }
}
