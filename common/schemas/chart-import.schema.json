{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/schemas/chart-import.schema.json",
  "title": "External chart import record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "import_id",
    "system",
    "source",
    "canonical_authority",
    "field_mappings",
    "conflicts",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "import_id": { "type": "string", "pattern": "^IMPORT-[A-F0-9]{16}$" },
    "system": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label", "schema_version"],
      "properties": {
        "kind": { "type": "string", "enum": ["structured_json", "csv", "text"] },
        "label": { "type": "string", "minLength": 1 },
        "schema_version": { "type": ["string", "null"] },
        "source_id": {
          "type": "string",
          "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)+$"
        }
      }
    },
    "canonical_authority": { "const": "native_calculator" },
    "field_mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["external_path", "canonical_path", "status"],
        "properties": {
          "external_path": { "type": "string", "minLength": 1 },
          "canonical_path": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["matched", "different", "missing_external", "unsupported"]
          }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["canonical_path", "external_value", "native_value", "resolution"],
        "properties": {
          "canonical_path": { "type": "string", "minLength": 1 },
          "external_value": {},
          "native_value": {},
          "resolution": {
            "type": "string",
            "enum": [
              "native_retained",
              "expected_lineage_difference",
              "boundary_policy_difference",
              "manual_review_required"
            ]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "status": { "type": "string", "enum": ["accepted", "partial", "rejected"] }
  }
}
