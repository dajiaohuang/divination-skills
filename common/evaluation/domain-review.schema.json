{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/common/evaluation/domain-review.schema.json",
  "title": "Per-system domain review batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["system", "release", "status", "reviewer_id", "reviewed_at", "evidence", "case_reviews", "notes"],
  "properties": {
    "system": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "release": { "type": "string", "pattern": "^(0|[1-9][0-9]*)[.](0|[1-9][0-9]*)[.](0|[1-9][0-9]*)$" },
    "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
    "reviewer_id": { "type": ["string", "null"] },
    "reviewed_at": { "type": ["string", "null"], "format": "date-time" },
    "evidence": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/evidence" }
      ]
    },
    "case_reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "decision", "notes"],
        "properties": {
          "case_id": { "type": "string", "pattern": "^CASE-[A-Z0-9-]+$" },
          "decision": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
          "notes": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "accepted" } }, "required": ["status"] },
      "then": {
        "properties": {
          "reviewer_id": { "type": "string", "minLength": 1 },
          "reviewed_at": { "type": "string", "format": "date-time" },
          "evidence": { "$ref": "#/$defs/evidence" }
        }
      }
    }
  ],
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["locator", "sha256", "retained_in_repository"],
      "properties": {
        "locator": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "retained_in_repository": { "type": "boolean" }
      }
    }
  }
}
