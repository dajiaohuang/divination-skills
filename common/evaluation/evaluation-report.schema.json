{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/schemas/evaluation-report.schema.json",
  "title": "Layered evaluation report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "system", "release", "generated_by", "corpus", "layers", "overall"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "system": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "release": { "type": "string", "pattern": "^[0-9]+[.][0-9]+[.][0-9]+$" },
    "generated_by": { "type": "string", "minLength": 1 },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_count", "sha256", "locators", "exclusions"],
      "properties": {
        "case_count": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "locators": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "exclusions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["case_id", "reason"],
            "properties": {
              "case_id": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "layers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["calculation", "rules", "narrative", "lineage", "human_review"],
      "properties": {
        "calculation": { "$ref": "#/$defs/metricMap" },
        "rules": { "$ref": "#/$defs/metricMap" },
        "narrative": { "$ref": "#/$defs/metricMap" },
        "lineage": { "$ref": "#/$defs/metricMap" },
        "human_review": { "$ref": "#/$defs/metricMap" }
      }
    },
    "overall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["technical_pass", "release_ready", "blocking_reasons"],
      "properties": {
        "technical_pass": { "type": "boolean" },
        "release_ready": { "type": "boolean" },
        "blocking_reasons": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    }
  },
  "$defs": {
    "metricMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/metric" }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["numerator", "denominator", "value", "threshold", "comparison", "passed", "evidence"],
      "properties": {
        "numerator": { "type": "integer", "minimum": 0 },
        "denominator": { "type": "integer", "minimum": 1 },
        "value": { "type": "number", "minimum": 0, "maximum": 1 },
        "threshold": { "type": "number", "minimum": 0, "maximum": 1 },
        "comparison": { "type": "string", "enum": ["minimum", "maximum"] },
        "passed": { "type": "boolean" },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}
