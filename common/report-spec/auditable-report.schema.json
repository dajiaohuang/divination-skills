{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://divination-skills.local/schemas/auditable-report.schema.json",
  "title": "Cross-system auditable result envelope",
  "type": "object",
  "required": [
    "schema_version",
    "engine",
    "normalized_input",
    "computed_facts",
    "derived_findings",
    "narrative",
    "validation"
  ],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+[.][0-9]+[.][0-9]+$" },
    "engine": {
      "type": "object",
      "required": ["name", "version", "source_ids"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "dependencies": { "type": "object" },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^SRC-[A-Z0-9]+(?:-[A-Z0-9]+)+$" }
        }
      },
      "additionalProperties": true
    },
    "raw_input": { "type": "object" },
    "normalized_input": { "type": "object" },
    "audit": { "type": "object" },
    "computed_facts": { "type": "object" },
    "derived_findings": { "type": "array", "items": { "type": "object" } },
    "narrative": { "type": ["object", "null"] },
    "validation": {
      "type": "object",
      "required": ["status", "warnings"],
      "properties": {
        "status": { "type": "string", "enum": ["valid", "invalid"] },
        "warnings": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
